<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title><%= title %></title>
        <link rel="icon" type="image/svg" href="arrows.svg" />
        <link rel="stylesheet" href="/styles.css" />
    </head>
    <body>
        <main>
            <header>
                <h1><%= title %></h1>
                <p class="meta">Last updated: <%= generatedAt %></p>
                <p class="meta">Router uptime: <%= uptime %></p>
            </header>
            <section class="card current-bandwidth">
                <h2>Current bandwidth (<%= pollIntervalSeconds %> seconds)</h2>
                <div class="grid two">
                    <div class="utilization">
                        <div class="label">Utilization</div>
                        <div class="value">0</div>
                    </div>
                    <div class="inbound">
                        <div class="label">Inbound</div>
                        <div class="value">0</div>
                    </div>
                    <div class="outbound">
                        <div class="label">Outbound</div>
                        <div class="value">0</div>
                    </div>
                    <div class="packets">
                        <div class="label">Packets/s</div>
                        <div class="value">In 0 / Out 0</div>
                    </div>
                    <div class="errors">
                        <div class="label">Errors</div>
                        <div class="value">In 0 / Out 0</div>
                    </div>
                    <div class="discards">
                        <div class="label">Discards</div>
                        <div class="value">In 0 / Out 0</div>
                    </div>
                    <div class="sample">
                        <div class="label">Sample</div>
                        <div class="value"></div>
                    </div>
                </div>
            </section>
            <section class="card">
                <h2>Interface</h2>
                <div class="grid two">
                    <div>
                        <div class="label">Name</div>
                        <div class="value"><%= interface.name %></div>
                        <div class="muted">Index: <%= interface.index %></div>
                    </div>
                    <div>
                        <div class="label">Status</div>
                        <div class="value">
                            <span class="badge"><%= interface.status %></span>
                        </div>
                    </div>
                    <div>
                        <div class="label">Speed</div>
                        <div class="value"><%= interface.speed %></div>
                    </div>
                </div>
            </section>
            <section class="card">
                <h2>Daily trend (last <%= daysToKeep %> days)</h2>
                <% if (dailyLines.length) { %>
                <div class="trend-container">
                    <pre><%= dailyLines.join('\n') %></pre>
                </div>
                <% } else { %>
                <p class="meta">No daily trend data yet.</p>
                <% } %>
            </section>
            <section class="card">
                <h2>Database</h2>
                <ul class="list">
                    <li>
                        Total raw points: <%= databaseStats.total_raw_points %>
                    </li>
                    <li>Days with data: <%= databaseStats.days_with_data %></li>
                    <li>
                        Points today: <%= databaseStats.current_day_points %>
                    </li>
                    <% if (databaseStats.oldest_timestamp) { %>
                    <li>
                        Oldest sample: <%= databaseStats.oldest_timestamp %>
                    </li>
                    <% } %> <% if (databaseStats.newest_timestamp) { %>
                    <li>
                        Newest sample: <%= databaseStats.newest_timestamp %>
                    </li>
                    <% } %>
                </ul>
            </section>
            <section class="card">
                <h2>JSON endpoints</h2>
                <ul class="list">
                    <% endpoints.forEach(function(endpoint) { %>
                    <li>
                        <a href="<%= endpoint.path %>"><%= endpoint.label %></a>
                    </li>
                    <% }) %>
                </ul>
            </section>
        </main>

        <script type="text/javascript">
            <%- formatBandwidth %>

            function updateBandwidthUI(data) {
              const inBoundEl = document.querySelector('.current-bandwidth .inbound .value')
              const outBoundEl = document.querySelector('.current-bandwidth .outbound .value')
              const utilizationEl = document.querySelector('.current-bandwidth .utilization .value')
              const errorsEl = document.querySelector('.current-bandwidth .errors .value')
              const packetsEl = document.querySelector('.current-bandwidth .packets .value')
              const discardsEl = document.querySelector('.current-bandwidth .discards .value')
              const sampleEl = document.querySelector('.current-bandwidth .sample .value')
              if (inBoundEl) inBoundEl.textContent = formatBandwidth(data.in_bps)
              if (outBoundEl) outBoundEl.textContent = formatBandwidth(data.out_bps)
              if (utilizationEl) utilizationEl.textContent = data.utilization.toFixed(2) + '%'
              if (errorsEl) errorsEl.textContent = 'In ' + data.in_errors_rate.toFixed(0) + ' / Out ' + data.out_errors_rate.toFixed(0)
              if (packetsEl) packetsEl.textContent = 'In ' + data.in_packets_rate.toFixed(0) + ' / Out ' + data.out_packets_rate.toFixed(0)
              if (discardsEl) discardsEl.textContent = 'In ' + data.in_discards_rate.toFixed(0) + ' / Out ' + data.out_discards_rate.toFixed(0)
              if (sampleEl) sampleEl.textContent = new Date(data.timestamp).toLocaleString()
            }

            async function fetchBandwidthData() {
              try {
                const response = await fetch('/api/bandwidth')
                if (!response.ok) throw new Error('Failed to fetch bandwidth data')
                const data = await response.json()
                updateBandwidthUI(data)
              } catch (error) {
                console.error('Error fetching bandwidth data:', error)
              }
            }

            document.addEventListener('DOMContentLoaded', function() {
              let interval
              let pollingInterval = <%= pollIntervalSeconds %> * 1000

              const startPolling = () => {
                fetchBandwidthData()
                interval = setInterval(fetchBandwidthData, pollingInterval)
              }

              const stopPolling = () => {
                clearInterval(interval)
              }

              if (document.visibilityState === 'visible') startPolling()

              document.addEventListener('visibilitychange', function() {
                if (document.visibilityState === 'visible') startPolling()
                else stopPolling()
              })

              window.addEventListener('beforeunload', () => stopPolling())
            })
        </script>
    </body>
</html>
