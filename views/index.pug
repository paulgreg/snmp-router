doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title= title
    link(rel="stylesheet" href="/styles.css")
  body
    main
        header
          h1= title
          p.meta
            | Last updated: #{generatedAt}
          p.meta Router uptime: #{uptime}
        section.card.current-bandwidth
          h2 Current bandwidth (#{pollIntervalSeconds} seconds)
          .grid.two
            div.inbound
              div.label Inbound
              div.value 0
              div.muted Utilization: 0%
            div.outbound
              div.label Outbound
              div.value 0
              div.muted Errors/s: 0 | Discards/s: 0
            div.errors
              div.label Errors
              div.value In 0 / Out 0
              div.muted Packets/s: 0 in / 0 out
            div.discards
              div.label Discards
              div.value In 0 / Out 0
              div.muted.sample Sample: 0
        section.card
          h2 Interface
          .grid.two
            div
              div.label Name
              div.value #{interface.name}
              div.muted Index: #{interface.index}
            div
              div.label Status
              div.value
                span.badge #{interface.status}
            div
              div.label Speed
              div.value #{interface.speed}
              div.muted ifHighSpeed: #{interface.highSpeed} Mbps
            div
              div.label Polled speed
              div.value #{interface.speedMbps} Mbps
              div.muted From SNMP ifHighSpeed/ifSpeed
        section.card
          h2 Daily trend (last #{daysToKeep} days)
          if dailyLines.length
            pre= dailyLines.join('\n')
          else
            p.meta No daily trend data yet.
        section.card
          h2 Database
          ul.list
            li Total raw points: #{databaseStats.total_raw_points}
            li Days with data: #{databaseStats.days_with_data}
            li Points today: #{databaseStats.current_day_points}
            if databaseStats.oldest_timestamp
              li Oldest sample: #{databaseStats.oldest_timestamp}
            if databaseStats.newest_timestamp
              li Newest sample: #{databaseStats.newest_timestamp}
        section.card
          h2 JSON endpoints
          ul.list
            each endpoint in endpoints
              li
                a(href=endpoint.path)= endpoint.label

        script.
          function formatBitsPerSecond(bps) {
            if (bps < 1000) return bps.toFixed(2) + ' bps';
            if (bps < 1000000) return (bps / 1000).toFixed(2) + ' Kbps';
            if (bps < 1000000000) return (bps / 1000000).toFixed(2) + ' Mbps';
            return (bps / 1000000000).toFixed(2) + ' Gbps';
          }

          function updateBandwidthUI(data) {
            const inBoundEl = document.querySelector('.current-bandwidth .inbound .value');
            const outBoundEl = document.querySelector('.current-bandwidth .outbound .value');
            const utilizationEl = document.querySelector('.current-bandwidth .inbound .muted');
            const errorsEl = document.querySelector('.current-bandwidth .outbound .muted');
            const errorsDetailEl = document.querySelector('.current-bandwidth .errors .value');
            const packetsEl = document.querySelector('.current-bandwidth .errors .muted');
            const discardsEl = document.querySelector('.current-bandwidth .discards .value');
            const discardsDetailEl = document.querySelector('.current-bandwidth .discards .muted');
            const sampleEl = document.querySelector('.current-bandwidth .sample');

            if (inBoundEl) inBoundEl.textContent = formatBitsPerSecond(data.in_bps);
            if (outBoundEl) outBoundEl.textContent = formatBitsPerSecond(data.out_bps);
            if (utilizationEl) utilizationEl.textContent = 'Utilization: ' + data.utilization.toFixed(2) + '%';
            if (errorsEl) errorsEl.textContent = 'Errors/s: ' + data.out_errors_rate.toFixed(2) + ' | Discards/s: ' + data.out_discards_rate.toFixed(2);
            if (errorsDetailEl) errorsDetailEl.textContent = 'In ' + data.in_errors_rate.toFixed(2) + ' / Out ' + data.out_errors_rate.toFixed(2);
            if (packetsEl) packetsEl.textContent = 'Packets/s: ' + data.in_packets_rate.toFixed(2) + ' in / ' + data.out_packets_rate.toFixed(2);
            if (discardsEl) discardsEl.textContent = 'In ' + data.in_discards_rate.toFixed(2) + ' / Out ' + data.out_discards_rate.toFixed(2);
            if (sampleEl) sampleEl.textContent = 'Sample: ' + new Date(data.timestamp).toLocaleString();
          }

          async function fetchBandwidthData() {
            try {
              const response = await fetch('/api/bandwidth');
              if (!response.ok) throw new Error('Failed to fetch bandwidth data');
              const data = await response.json();
              updateBandwidthUI(data);
            } catch (error) {
              console.error('Error fetching bandwidth data:', error);
            }
          }

          document.addEventListener('DOMContentLoaded', function() {
              fetchBandwidthData(); 
              const interval = setInterval(fetchBandwidthData, #{pollIntervalSeconds} * 1000);
              window.addEventListener('beforeunload', () => clearInterval(interval));
          });
